<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Debug-only test hook: lets a tester force an immediate background WatchSyncWorker run via
         adb. Merged into the debug variant only; absent from release. -->
    <application>
        <receiver
            android:name=".work.DebugSyncTriggerReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="dev.jaredhq.dashboardandroid.DEBUG_SYNC_NOW" />
            </intent-filter>
        </receiver>

        <!-- Debug-only: force an immediate JaredFeedWorker run (Daily Intelligence
             feed → native notifications). See DebugJaredFeedTriggerReceiver. -->
        <receiver
            android:name=".work.DebugJaredFeedTriggerReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="dev.jaredhq.dashboardandroid.DEBUG_JARED_FEED_NOW" />
            </intent-filter>
        </receiver>

        <!-- Debug-only: repoint the app at a different watch MAC (pairing without a rebuild).
             See DebugSetWatchMacReceiver. -->
        <receiver
            android:name=".work.DebugSetWatchMacReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="dev.jaredhq.dashboardandroid.DEBUG_SET_WATCH_MAC" />
            </intent-filter>
        </receiver>

        <!-- Debug-only: force weather + schedule pushes over the existing link.
             See DebugPushWatchNowReceiver. -->
        <receiver
            android:name=".work.DebugPushWatchNowReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="dev.jaredhq.dashboardandroid.DEBUG_PUSH_WATCH_NOW" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
