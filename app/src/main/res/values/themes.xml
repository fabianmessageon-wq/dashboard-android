<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Compose drives the real theming (ui/theme). This Material3 parent only
         needs to exist for the manifest and to avoid an ActionBar flash. The
         dark base + warm brand window background prevents a white flash before
         the dark-first Compose UI paints. -->
    <style name="Theme.DashboardAndroid" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/brand_bg</item>
        <item name="android:statusBarColor">@color/brand_bg</item>
        <item name="android:navigationBarColor">@color/brand_bg</item>
    </style>
</resources>
