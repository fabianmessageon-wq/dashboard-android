<?xml version="1.0" encoding="utf-8"?>
<!-- The dashboard "constellation" brand mark (src/components/brand/brand-mark.tsx):
     four nodes rising along connecting edges — reads as both a progress streak
     and a knowledge graph. Painted in warm cream and centred in the adaptive
     safe zone. The 32-unit source mark is scaled ×2 and offset by 22 into the
     108 viewport (x' = 22 + 2x, y' = 22 + 2y). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Edges -->
    <path
        android:strokeColor="#FDF6EE"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M39,67 L53,45 L69,57 M53,45 L65,38" />
    <!-- Nodes -->
    <path android:fillColor="#FDF6EE" android:pathData="M39,67 m-4.8,0 a4.8,4.8 0 1,0 9.6,0 a4.8,4.8 0 1,0 -9.6,0z" />
    <path android:fillColor="#FDF6EE" android:pathData="M53,45 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0z" />
    <path android:fillColor="#FDF6EE" android:pathData="M69,57 m-3.4,0 a3.4,3.4 0 1,0 6.8,0 a3.4,3.4 0 1,0 -6.8,0z" />
    <path android:fillColor="#FDF6EE" android:pathData="M65,38 m-2.4,0 a2.4,2.4 0 1,0 4.8,0 a2.4,2.4 0 1,0 -4.8,0z" />
</vector>
