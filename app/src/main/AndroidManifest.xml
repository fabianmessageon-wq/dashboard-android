<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Talks to the user's self-hosted dashboard over HTTPS (Tailscale URL). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Surface dashboard reminders + the daily quote as native notifications.
         Runtime-requested on Android 13+ (see MainActivity); the worker no-ops
         if the user declines. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- BLE permissions — Android 12+ (API 31) uses BLUETOOTH_SCAN / BLUETOOTH_CONNECT.
         Runtime-requested on the Watch tab; BLUETOOTH / BLUETOOTH_ADMIN are for API < 31. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- neverForLocation: this app connects to a known user-owned watch and never
         derives location from BLE scan results, so location permission is not
         needed for scanning on Android 12+. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Pre-Android-12 BLE scanning required location access. Both are capped at API 30:
         on 12+ the neverForLocation BLUETOOTH_SCAN flag above covers scanning without any
         location permission (verified on a real Android 14 phone). COARSE is declared
         alongside FINE because Android lets users grant only approximate location, and
         Lint (CoarseFineLocation) requires both whenever FINE is requested. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:maxSdkVersion="30" />
    <!-- NEARBY_DEVICES is implicitly covered by BLUETOOTH_SCAN / BLUETOOTH_CONNECT on Android 12+. -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <!-- Capture dictation uses the platform speech recognizer via
         RecognizerIntent.ACTION_RECOGNIZE_SPEECH. The recognizer app owns the
         microphone, so this app requests NO RECORD_AUDIO. This <queries> entry
         lets SpeechRecognizer.isRecognitionAvailable() resolve the recognizer
         service under Android 11+ package visibility. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:name=".DashboardApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DashboardAndroid">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DashboardAndroid">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Glance "Today" widget. -->
        <receiver
            android:name=".widget.TodayWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_widget_info" />
        </receiver>

        <!-- Glance "Fast capture" widget — deep-links into the Capture screen. -->
        <receiver
            android:name=".widget.CaptureWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/capture_widget_info" />
        </receiver>

    </application>

</manifest>
